{
  "name": "pi-adr",
  "version": "0.3.0",
  "description": "Create and maintain Architecture Decision Records with pi.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "skill",
    "adr",
    "architecture-decision-records"
  ],
  "pi": {
    "skills": ["./skills"],
    "image": "https://raw.githubusercontent.com/unravel-team/pi-adr/main/assets/banner.png"
  },
  "scripts": {
    "adr": "bun run skills/adr/scripts/adr.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --config vitest.config.unit.ts --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
